<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hello, I am an EJS View!</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1> THIS IS THE BLACK OWNED BUSINESS INDEX 🐆 </h1>
    <% if (name === "BlackOwnedBrands") { %>
    <p>The name sent to this view is <%= name %></p>
    <% } else { %>
    <p>Welcome Intruder! NO VIEWS 4 U!</p>
    <% } %>
    <form action="/api/BOBrands" method="POST">
    <!-- <form> -->
        <input type="number" name="id" placeholder="Black Owned Brands ID#" />
        <input type="text" name="name" placeholder="BlackFounder Name" />
        <input type="text" name="type1" placeholder="Black Owned Brands Type 1" />
        <input type="text" name="type2" placeholder="Black Owned BrandsType 2" />
        <button>Submit</button>
    </form>
</body>
</html>